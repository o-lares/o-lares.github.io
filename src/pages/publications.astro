---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicationList from "../components/PublicationList.astro";

const publications = (await getCollection("publications")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Publications - Oscar Lares">
  <section class="section">
    <p class="eyebrow">Research</p>
    <h1 class="page-title">Publications and Presentations</h1>
    <p class="section-intro">
      Papers, presentations, and transportation research work spanning machine learning, crash modeling, and traffic data analysis.
    </p>
    <PublicationList publications={publications} />
  </section>
</BaseLayout>
